<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>random   <%= 2 + 2 + 3%></h1>
    <h1>random   <%= number%></h1>


    <% if(number % 2 == 0){%>
        <h1>even number</h1>
    <% }else{%>
        <h1>odd number</h1>
    <% }%>
</body>
</html>