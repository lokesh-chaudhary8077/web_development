<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/app.css">
    <title>Document</title>
</head>
<body>
    <h1>Display all the Blogs</h1>
   <% for(let i of comments){ %>
    <div>
        <h1>ID is: <%= i.id %></h1>
        <h2>Name is: <%= i.username %></h2>
        <h4>Comment is: <%= i.comment %></h4>
        <a href="/blogs/<%= i.id %>">Show</a>
        <br>
        <a href="/blogs/<%= i.id %>/edit">Edit</a>
        <form action="/blogs/<%= i.id %>?_method" method="'POST">
            <button type="submit">Delete</button>
        </form>
        
    </div>
    <%}%>

    </section>
</body>
</html>